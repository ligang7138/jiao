{
  "name": "vue-admin",
  "version": "1.0.0",
  "description": "教务大兴采购管理系统 - 管理后台",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "bash ../scripts/dev-admin.sh",
    "api:up": "cd ../laravel-api && docker compose up -d",
    "api:down": "cd ../laravel-api && docker compose down",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.0",
    "echarts": "^5.5.0",
    "element-plus": "^2.5.0",
    "lodash-es": "^4.17.0",
    "nprogress": "^0.2.0",
    "path-browserify": "^1.0.1",
    "pinia": "^2.1.0",
    "spark-md5": "^3.0.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "prettier": "^3.2.0",
    "sass": "^1.71.0",
    "unplugin-auto-import": "^0.17.0",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.0",
    "vite-plugin-compression": "^0.5.0",
    "vite-plugin-svg-icons": "^2.0.0"
  }
}
