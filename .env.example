APP_NAME=教务大兴采购管理系统
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

# 前端 CORS（逗号分隔，JWT 模式 supports_credentials=false）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Sanctum stateful 域名（JWT 项目留空，勿填 localhost:3000）
SANCTUM_STATEFUL_DOMAINS=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# 数据库配置
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=jiaowei_daxing
DB_USERNAME=root
DB_PASSWORD=root123456

# Redis 配置
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Session 配置
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# 缓存配置
CACHE_STORE=redis
CACHE_PREFIX=jiaowei_cache_

# JWT 配置
JWT_SECRET=
JWT_TTL=120
JWT_REFRESH_TTL=20160

# 文件上传配置
UPLOAD_DRIVER=local
UPLOAD_MAX_SIZE=51200

# 跨域配置
CORS_ALLOWED_ORIGINS=*
